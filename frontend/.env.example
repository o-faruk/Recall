# Recall frontend env (Vite exposes only VITE_-prefixed vars to the browser).
# Copy to .env.local for local dev.

# true  = run fully simulated, no backend needed ($0, great for UI dev)
# false = call the real API at VITE_API_BASE_URL (after Phase 5 wires API Gateway)
VITE_USE_MOCK=true

# Your API Gateway base URL (only used when VITE_USE_MOCK=false)
VITE_API_BASE_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/prod

# Cognito (required in live mode for login). Region is embedded in the pool ID.
VITE_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
VITE_COGNITO_CLIENT_ID=your-app-client-id
