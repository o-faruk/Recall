# ----------------------------------------------------------------------
# Recall — environment variable template
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Lambdas read these from their function "Environment variables" config in
# the AWS console (not from this file) — this file documents what each one is.
# ----------------------------------------------------------------------

# --- AWS (only needed for local scripts/SDK calls; Lambdas use their IAM role) ---
AWS_REGION=us-east-1

# --- S3 ---
S3_BUCKET_NAME=recall-documents-omar-2026

# --- DynamoDB ---
DYNAMO_TABLE_NAME=RecallDocuments

# --- Feature flags: flip to "true" to use the real services (Phase 3+) ---
# Keep these "false" through Phases 1–2 so everything runs for free.
USE_REAL_EMBEDDINGS=false
USE_REAL_PINECONE=false
USE_REAL_CLAUDE=false

# --- Pinecone (only used when USE_REAL_PINECONE=true) ---
PINECONE_API_KEY=
PINECONE_INDEX=recall
PINECONE_HOST=

# --- Embeddings (only used when USE_REAL_EMBEDDINGS=true) ---
# Free/cheap option, e.g. a hosted sentence-transformer or OpenAI text-embedding-3-small
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_DIM=1536

# --- Anthropic Claude (only used when USE_REAL_CLAUDE=true) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# --- Frontend (Vite) — must be prefixed with VITE_ to be exposed to the browser ---
VITE_API_BASE_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/prod
